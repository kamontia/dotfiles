# Ghostty Configuration

# Theme (Standard built-in names)
# theme = One Half
theme = Atom One Dark


# Font
font-family = "JetBrainsMono Nerd Font"
font-codepoint-map = U+3000-U+9FFF,U+F900-U+FAFF,U+FF00-U+FFEF=Hiragino Sans W5
font-size = 14

# Window
window-padding-x = 10
window-padding-y = 10
window-decoration = true
macos-option-as-alt = true
background-opacity = 0.95
background-blur-radius = 0

# Keybindings
keybind = super+ctrl+f=toggle_fullscreen
keybind = super+t=new_tab
keybind = super+w=close_tab
keybind = super+h=previous_tab
keybind = super+l=next_tab
keybind = super+shift+r=reload_config
keybind = super+b=csi:98;9u
keybind = super+shift+b=csi:66;9u
keybind = super+e=csi:101;9u
keybind = super+d=unbind
